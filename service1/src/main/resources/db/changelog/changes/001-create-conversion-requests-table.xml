<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-conversion-requests-table" author="Elizaveta">

        <createTable tableName="conversion_requests">

            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="json_result" type="TEXT">
                <constraints nullable="false"/>
            </column>

            <column name="request_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="processing_time_ms" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="xml_tags_count" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="json_keys_count" type="INTEGER">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <createIndex indexName="idx_conversion_requests_request_date"
                     tableName="conversion_requests">
            <column name="request_date"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>